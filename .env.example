PYTHONPATH=src

# --- Docker Compose configuration ---
AIRFLOW_DB_NAME=airflow
PROJECT_DB_NAME=project
POSTGRES_HOST=postgres_service

# --- Logging ---
# Airflow internal log level (root logger: scheduler, webserver, executor)
LOGGING_LEVEL=INFO
# App log level (Loguru / MY_LOGGER) — only used inside Airflow container
APP_LOGGING_LEVEL=DEBUG
LOGGER_NAME=MY_LOGGER

# --- Logger theme override (optional) ---
# Force terminal theme for log colors instead of auto-detection (OSC 10/11).
# Valid values: dark, light
# TERMINAL_THEME=dark