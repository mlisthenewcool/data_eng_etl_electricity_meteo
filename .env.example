# Variables for Docker Compose substitution (${VAR} in docker-compose.yaml).
# Copy to .env and fill in values. Do NOT add local-only settings here.
# For local dev overrides (PYTHONPATH, POSTGRES_HOST, etc.), use .env.local
# (gitignored) — see .env.local.example.

AIRFLOW_DB_NAME=airflow
POSTGRES_DB_NAME=project
POSTGRES_HOST=postgres_service
POSTGRES_PORT=5432
LOGGING_LEVEL=INFO
