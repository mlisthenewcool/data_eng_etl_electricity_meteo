# Shared configuration — read by Docker Compose (${VAR} substitution) AND by
# pydantic-settings (dotenv source, lower priority than env vars).
#
# Copy to .env and fill in values.
#
# Only put values that work in BOTH contexts (Docker and local).
# Docker-only values (POSTGRES_HOST) are hardcoded directly
# in docker-compose.yaml `environment:` section.
#
# Postgres credentials are managed via Docker secrets (secrets/ directory),
# not environment variables.

# e.g. 5432
POSTGRES_PORT=REPLACE_ME
# e.g. electricity_meteo
POSTGRES_DB_NAME=REPLACE_ME
# e.g. airflow (separate DB for Airflow metadata)
AIRFLOW_DB_NAME=REPLACE_ME
# e.g. INFO (debug, info, warning, error, critical)
LOGGING_LEVEL=REPLACE_ME
